rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Only signed-in users can write to their own kyc folder
    // Only the backend (Admin SDK) can read these files.
    match /kyc/{userId}/{fileName} {
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024 // 5MB limit
                   && request.resource.contentType.matches('image/.*');
      allow read: if false; // Only Admin SDK can read
    }

    // Profile photos — public read (shown on listings), owner write only.
    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 3 * 1024 * 1024 // 3MB limit
                   && request.resource.contentType.matches('image/.*');
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
